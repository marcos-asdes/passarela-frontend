    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "redux-persist": "^6.0.0",
    "redux-persist-transform-encrypt": "^5.1.1",
    "socket.io-client": "^4.8.3",
    "styled-components": "^6.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
