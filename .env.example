# URL base da API do backend (Nest). Fora do Docker ou com backend rodando via seu próprio
# docker-compose (porta 3000 publicada no host), localhost:3000 funciona nos dois casos.
VITE_API_URL=http://localhost:3000

# Chave usada para criptografar (AES) o estado sensível persistido no localStorage (ex.: token de
# login) — gerar com alta entropia (ex.: openssl rand -base64 32), nunca reaproveitar entre ambientes.
# Só entra em uso fora de dev (import.meta.env.DEV) — em dev o estado persiste em texto puro, de propósito.
VITE_REDUX_PERSIST_ENCRYPTION_KEY=troque-por-uma-chave-forte-de-32-caracteres-ou-mais
